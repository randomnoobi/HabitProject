# Desk Talk — Configuration
# Copy this file to .env and fill in your values.

# ── LLM (pick ONE — first match wins) ──

# Option 1: OpenAI
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Option 2: Google Gemini (free tier available)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Option 3: Groq (free tier — generous limits, fast!)
#   Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Option 4: Ollama (fully local, no API key needed)
#   Install from https://ollama.com e.g. ollama pull gpt-oss:20b
#   - Text chat + JSON-style LLM tasks use OLLAMA_MODEL.
#   - Object *boxes* on camera are YOLO (YOLO_MODEL below), not the LLM.
#   - Image / lost-item vision (VLM) needs a *vision* model. gpt-oss:20b is text-only in Ollama;
#     set LOST_VISION_MODEL to e.g. llava or llama3.2-vision (ollama pull those separately).
OLLAMA_URL=
OLLAMA_MODEL=llama3.2
# LOST_VISION_MODEL=llava

# Rate limiting — min seconds between LLM calls (prevent quota burn)
MIN_LLM_INTERVAL=6

# ── Camera ──

# Comma-separated camera indices — one thread per camera (default: 0)
# Example for two cameras: CAMERA_INDICES=0,1
CAMERA_INDICES=0

# YOLO / Ultralytics — default weights/yolo26n.pt (downloaded if missing; override with full path)
# YOLO_MODEL=weights/yolo26n.pt
# YOLO confidence threshold (default: 0.45)
CONFIDENCE=0.45

# ── Events ──

# Minimum seconds between messages for the same event type (default: 25)
EVENT_COOLDOWN=25

# Proximity ratio — fraction of frame width that counts as "close" (default: 0.22)
PROXIMITY_RATIO=0.22

# Temporal smoothing — consecutive frames needed to confirm appear/disappear
APPEAR_FRAMES=10
DISAPPEAR_FRAMES=40
